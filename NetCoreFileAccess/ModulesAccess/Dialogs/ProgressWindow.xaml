<mah:MetroWindow x:Class="NetCoreFileAccess.ModulesAccess.Dialogs.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NetCoreFileAccess.ModulesAccess.Dialogs"
        mc:Ignorable="d"
        Title="Connecting ..." 
        Height="150" 
        Width="400" ResizeMode="NoResize" ShowInTaskbar="False" WindowStartupLocation="CenterScreen" Cursor="Wait" Topmost="True">
    <Grid>
        <mah:ProgressRing Name="Progress" HorizontalAlignment="Left" Height="114" Margin="23,0,0,0" Width="110" RenderTransformOrigin="0.5,0.5" mah:ScrollViewerHelper.IsHorizontalScrollWheelEnabled="False"/>
        <Label Name="LbProgessInfo" Content="Connecting to FTP server" Height="30" Margin="156,0,22,0" VerticalAlignment="Center" RenderTransformOrigin="0,0.5" mah:ScrollViewerHelper.IsHorizontalScrollWheelEnabled="False" Background="{x:Null}" Grid.ColumnSpan="4" />

    </Grid>
</mah:MetroWindow>
